<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task 4: Login Exercise</title>
</head>

<body>
    <h1>Task 4: Registration</h1>
    <h2>Register</h2>
    <form>
        <div>
            <label for="first-name"> First Name:</label>
            <input type="text" id="first-name" name="first-name" placeholder="John" required>

            <label for="last-name"> Last Name:</label>
            <input type="text" id="last-name" name="last-name" placeholder="Smith" required>
        </div>

        <div>
            <label for="radio-choice-1">Male</label>
            <input type="radio" id="radio-choice-1" name="radio-choice" value="choice-1">
            <label for="radio-choice-2">Female</label>
            <input type="radio" id="radio-choice-2" name="radio-choice" value="choice-1">
            <label for="radio-choice-3">Others</label>
            <input type="radio" id="radio-choice-3" name="radio-choice" value="choice-1">
        </div>

        <div> <label for="email"> Email:</label>
            <input id="email" name="email" type="email" required>
        </div>

        <div> <label for="password">Password:</label>
            <input id="password" name="password" type="password" maxlength="16" required>
        </div>

        <div> <label for="birthday">Birthday:</label>
            <input type="date" id="birthday" name="birthday">

        </div>


        <div> <input type="checkbox" id="checkbox" name="checkbox" value="checkbox">
            <label for="checkbox">I agree to the terms and conditions</label><br>
        </div>
        <div><input type="submit"></div>

    </form>

</body>

</html>